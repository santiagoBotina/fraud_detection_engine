# ms-transaction-evaluator
EVALUATOR_APP_PORT=3000
DYNAMO_DB_TRANSACTIONS_TABLE=ddb-transactions

# SERVICES
ZOOKEEPER_CONTAINER_NAME="zookeeper_fraud_engine"
ZOOKEEPER_PORT=2181

DYNAMO_CONTAINER_NAME="dynamo_db_fraud_engine"
DYNAMO_DB_PORT=8000
DYNAMO_DB_ENDPOINT=http://dynamodb:${DYNAMO_DB_PORT}

KAFKA_CONTAINER_NAME="kafka_fraud_engine"
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# ms-decision-service
DECISION_APP_PORT=3001
DYNAMO_DB_RULES_TABLE=ddb-rules
KAFKA_TRANSACTION_CREATED_TOPIC=Transaction.Created
KAFKA_DECISION_CALCULATED_TOPIC=Decision.Calculated

# ms-decision-service (rule evaluations)
DYNAMO_DB_RULE_EVALUATIONS_TABLE=ddb-rule-evaluations

# ms-fraud-score
FRAUD_SCORE_APP_PORT=3002
REDIS_PORT=6379
KAFKA_FRAUD_SCORE_REQUEST_TOPIC=FraudScore.Request
KAFKA_FRAUD_SCORE_CALCULATED_TOPIC=FraudScore.Calculated
DYNAMO_DB_FRAUD_SCORES_TABLE=ddb-fraud-scores

# Observability Stack
GRAFANA_PORT=3003
CADVISOR_PORT=8081
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
